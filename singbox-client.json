{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "type": "udp",
        "tag": "google",
        "server": "8.8.8.8",
        "detour": "select"
      },
      {
        "type": "local",
        "tag": "local"
      }
    ],
    "rules": [],
    "final": "google"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",

      "address": [
        "172.19.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "mtu": 9000,
      "auto_route": true,
      "strict_route": true,
      "stack": "system"
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "select",
      "outbounds": [
        "proxy",
        "direct"
      ]
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    },
    {
      "type": "socks",
      "tag": "proxy",
      "server": "127.0.0.1",
      "server_port": 1080
    }
  ],
  "route": {
    "default_domain_resolver": "google",
    "auto_detect_interface": true,
    "rules": [
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "inbound": [
          "tun-in"
        ],
        "action": "sniff",
        "timeout": "1s"
      },
      {
        "inbound": [
          "tun-in"
        ],
        "action": "resolve",
        "strategy": "prefer_ipv4"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      }
    ],
    "final": "select"
  }
}
