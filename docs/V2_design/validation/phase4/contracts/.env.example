# Deployment Configuration for Base Sepolia

# Your MetaMask private key (without 0x prefix)
# IMPORTANT: Never commit this file with real values!
PRIVATE_KEY=your_private_key_here

# Service wallet address (receives USDC payments)
SERVICE_WALLET_ADDRESS=0x729e71ff357ccefAa31635931621531082A698f6

# Relayer address (CDP Server Wallet address)
# This will be the address that calls permitAndSubscribe, executeRenewal, etc.
RELAYER_ADDRESS=your_cdp_server_wallet_address_here

# Base Sepolia RPC URL (optional, foundry has default)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Etherscan API key for contract verification (optional)
ETHERSCAN_API_KEY=your_etherscan_api_key_here
