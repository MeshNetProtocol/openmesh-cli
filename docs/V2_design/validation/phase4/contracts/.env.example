# Deployment Configuration for Base Sepolia

# Your MetaMask private key (without 0x prefix)
# IMPORTANT: Never commit this file with real values!
PRIVATE_KEY=your_private_key_here

# Service wallet address (receives USDC payments)
# For PoC: use your own MetaMask address
SERVICE_WALLET_ADDRESS=your_metamask_address_here

# Relayer address (calls permitAndSubscribe, executeRenewal, etc.)
# For PoC: use your own MetaMask address (same as SERVICE_WALLET_ADDRESS)
# For Production: use CDP Server Wallet address
RELAYER_ADDRESS=your_metamask_address_here

# Base Sepolia RPC URL (optional, foundry has default)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Etherscan API key for contract verification (optional)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# CDP (Coinbase Developer Platform) Configuration
# Get these from: https://portal.cdp.coinbase.com/
CDP_API_KEY_ID=your_cdp_api_key_id_here
CDP_API_KEY_SECRET=your_cdp_api_key_secret_here
CDP_WALLET_SECRET=your_cdp_wallet_secret_here

