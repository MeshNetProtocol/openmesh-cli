# ============================================================
# phase4 环境变量模板 — 复制为 .env 并填入真实值
# 注意: .env 文件绝对不能提交到 git！
# ============================================================

# 合约 owner 私钥（仅执行 set_relayer.js 时需要，用完立即清空）
# 对应地址: 0x490DC2F60aececAFF22BC670166cbb9d5DdB9241
OWNER_PRIVATE_KEY=

# CDP API 配置 (在 https://portal.cdp.coinbase.com/ 创建)
CDP_API_KEY_ID=your_cdp_api_key_id
CDP_API_KEY_SECRET=your_cdp_api_key_secret

# CDP Wallet Secret
CDP_WALLET_SECRET=your_cdp_wallet_secret

# CDP Server Wallet 配置
CDP_SERVER_WALLET_ACCOUNT_NAME=openmesh-vpn-1775870994810
CDP_SERVER_WALLET_ADDRESS=0x8c145d6ae710531A13952337Bf2e8A31916963F3

# 网络配置
NETWORK=base-sepolia

# CDP Paymaster & Bundler Endpoint
# 在 CDP Portal → Paymaster → Configuration → Base Sepolia 获取
CDP_PAYMASTER_ENDPOINT=https://api.developer.coinbase.com/rpc/v1/base-sepolia/YOUR_KEY
CDP_PAYMASTER_URL=https://api.developer.coinbase.com/rpc/v1/base-sepolia/YOUR_KEY

# 智能合约地址
VPN_SUBSCRIPTION_CONTRACT=0xE9FC83d46590fc7cB603bDA4A25cAb8AF32a02D2
USDC_CONTRACT=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# 收款地址
SERVICE_WALLET_ADDRESS=0x729e71ff357ccefAa31635931621531082A698f6
PAY_TO_ADDRESS=0x729e71ff357ccefAa31635931621531082A698f6

# Relayer 地址（CDP Smart Account 地址）
RELAYER_ADDRESS=0x10AB796695843043CF303Cc8C7a58E9498023768

# 服务配置
PORT=8080

# 自动续费配置
RENEWAL_CHECK_INTERVAL_SECONDS=60
RENEWAL_PRECHECK_HOURS=24
MAX_RENEWAL_FAILS=3

# ============================================================
# 链上提交配置（可选）
# ============================================================
# 设置为 true 启用真实链上提交，false 则只做本地 mock
ENABLE_CHAIN_SUBMISSION=false

# RPC 节点地址
CHAIN_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Relayer 私钥（用于签名并提交 authorizeChargeWithPermit 交易）
RELAYER_PRIVATE_KEY=

# 合约地址
VAULT_CONTRACT_ADDRESS=
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
