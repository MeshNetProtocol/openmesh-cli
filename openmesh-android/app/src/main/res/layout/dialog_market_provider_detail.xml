<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/detailProviderName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#DE000000"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detailProviderPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#2CB9D8"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detailProviderDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#8A000000"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/detailTagContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal" />

        <TextView
            android:id="@+id/detailStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#7A000000"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>

